# EzyBill Pro - Server Environment Configuration
# Copy this file to .env and update values for your environment

# Server
PORT=4000
NODE_ENV=production

# Security - MUST be set to a strong random value in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-strong-random-secret-here-minimum-32-chars

# CORS - Comma-separated list of allowed origins
# Development: http://localhost:5173,http://localhost:4000
# Production: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000

# Database
# Default location: server/data/ezybill.db (auto-created)
# DATABASE_PATH=./data/ezybill.db

# Optional: Set to 'true' to seed demo data on startup (not recommended for production)
# SEED_ON_STARTUP=false

# Logging (optional, future use)
# LOG_LEVEL=info
